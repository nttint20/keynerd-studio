<div class="hero full-width" style="background-color: {{ section.settings.background_color }};">
  <div class="hero__inner">
    <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    <p class="hero__subheading">{{ section.settings.subheading }}</p>
    {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
      <a class="hero__cta" href="{{ section.settings.cta_url }}">{{ section.settings.cta_label }}</a>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .hero {
    display: grid;
    grid-template-columns: var(--content-grid);
    padding: 100px 0;
    min-height: 60vh;
    align-items: center;
  }

  .hero__inner {
    grid-column: 2;
    max-width: 640px;
  }

  .hero__eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .hero__heading {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    color: var(--color-foreground);
    margin-bottom: 1.25rem;
  }

  .hero__subheading {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-foreground);
    opacity: 0.75;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero__cta {
    display: inline-block;
    padding: 14px 32px;
    background-color: var(--color-accent);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: var(--style-border-radius-inputs);
    transition: opacity 0.2s;
  }

  .hero__cta:hover {
    opacity: 0.88;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Homepage Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Handcrafted in Vietnam"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted with intention.\nBuilt for the obsessed."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Custom keycaps, 3D-printed figures, and resin lamps — each piece made to order, made to last."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FAFAF8"
    }
  ],
  "presets": [
    {
      "name": "Homepage Hero"
    }
  ]
}
{% endschema %}

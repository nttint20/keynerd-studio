<div class="featured-collections full-width">
  <div class="featured-collections__inner">
    {% if section.settings.heading != blank %}
      <h2 class="featured-collections__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="featured-collections__grid">
      {% for i in (1..3) %}
        {% liquid
          assign title_key = 'card_' | append: i | append: '_title'
          assign desc_key  = 'card_' | append: i | append: '_description'
          assign url_key   = 'card_' | append: i | append: '_url'
          assign title = section.settings[title_key]
          assign desc  = section.settings[desc_key]
          assign url   = section.settings[url_key]
        %}
        <a class="collection-card" href="{{ url | default: '#' }}">
          <div class="collection-card__media">
            <span class="collection-card__placeholder"></span>
          </div>
          <div class="collection-card__body">
            <h3 class="collection-card__title">{{ title }}</h3>
            {% if desc != blank %}
              <p class="collection-card__desc">{{ desc }}</p>
            {% endif %}
            <span class="collection-card__cta">Shop now &rarr;</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .featured-collections {
    padding: 80px var(--page-margin);
    background-color: var(--color-background);
  }

  .featured-collections__inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .featured-collections__heading {
    font-size: 1.8rem;
    color: var(--color-foreground);
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .featured-collections__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .featured-collections__grid {
      grid-template-columns: 1fr;
    }
  }

  .collection-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-foreground);
    border: 1px solid rgba(43,43,43,0.1);
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .collection-card:hover {
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
  }

  .collection-card__media {
    background-color: #F0EDE8;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .collection-card__placeholder {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: var(--color-accent);
    opacity: 0.35;
    display: block;
  }

  .collection-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .collection-card__title {
    font-size: 1.15rem;
    font-weight: 600;
  }

  .collection-card__desc {
    font-size: 0.9rem;
    line-height: 1.5;
    opacity: 0.7;
    flex: 1;
  }

  .collection-card__cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.5rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Our collections"
    },
    {
      "type": "header",
      "content": "Card 1"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Title",
      "default": "Custom Keycaps"
    },
    {
      "type": "text",
      "id": "card_1_description",
      "label": "Description",
      "default": "Artisan-crafted keycaps in resin, sculpted and painted to order."
    },
    {
      "type": "url",
      "id": "card_1_url",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Title",
      "default": "Custom 3D Figures"
    },
    {
      "type": "text",
      "id": "card_2_description",
      "label": "Description",
      "default": "Personalised 3D-printed figurines — characters, portraits, miniatures."
    },
    {
      "type": "url",
      "id": "card_2_url",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Card 3"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Title",
      "default": "Resin & Epoxy Lamps"
    },
    {
      "type": "text",
      "id": "card_3_description",
      "label": "Description",
      "default": "Handpoured resin lamps with botanicals, pigments, and LED lighting."
    },
    {
      "type": "url",
      "id": "card_3_url",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Featured Collections"
    }
  ]
}
{% endschema %}
